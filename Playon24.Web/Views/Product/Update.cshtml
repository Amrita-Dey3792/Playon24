@using Playon24.PresentationLayer.Modules.Products.ViewModels
@{
    ViewData["Title"] = "Update Product";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@model ProductEditViewModel

<div class="lg:min-w-[700px] max-w-screen-sm mx-auto p-6">
    <h1 class="text-2xl font-semibold text-gray-900 dark:text-white mb-8">Update Product</h1>

    <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-3xl p-8">

        <form asp-action="Update" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data">

            <input asp-for="Id" type="hidden" />

            <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm mb-6"></div>

            <div class="mb-6">
                <label asp-for="ProductName" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2"></label>
                <input asp-for="ProductName"
                       class="w-full px-5 py-4 border border-gray-300 dark:border-gray-600 rounded-2xl focus:outline-none focus:border-blue-500 bg-transparent text-gray-900 dark:text-white" />
                <span asp-validation-for="ProductName" class="text-red-500 text-sm mt-1 block"></span>
            </div>

            <div class="mb-6">
                <label asp-for="Description" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2"></label>
                <textarea asp-for="Description" rows="4"
                          class="w-full px-5 py-4 border border-gray-300 dark:border-gray-600 rounded-3xl focus:outline-none focus:border-blue-500 bg-transparent text-gray-900 dark:text-white resize-y"></textarea>
                <span asp-validation-for="Description" class="text-red-500 text-sm mt-1 block"></span>
            </div>

            <div class="mb-6">
                <label asp-for="UnitPrice" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2"></label>
                <input asp-for="UnitPrice" type="text"
                       class="w-full px-5 py-4 border border-gray-300 dark:border-gray-600 rounded-2xl focus:outline-none focus:border-blue-500 bg-transparent text-gray-900 dark:text-white" />
                <span asp-validation-for="UnitPrice" class="text-red-500 text-sm mt-1 block"></span>
            </div>

            <div class="mb-6">
                <label asp-for="StockQuantity" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2"></label>
                <input asp-for="StockQuantity"
                       class="w-full px-5 py-4 border border-gray-300 dark:border-gray-600 rounded-2xl focus:outline-none focus:border-blue-500 bg-transparent text-gray-900 dark:text-white" />
                <span asp-validation-for="StockQuantity" class="text-red-500 text-sm mt-1 block"></span>
            </div>

            <div class="mb-8 flex items-center gap-3">
                <input asp-for="IsActive" class="h-5 w-5 rounded border-gray-300 text-blue-600 focus:ring-blue-500" />
                <label asp-for="IsActive" class="text-sm font-medium text-gray-700 dark:text-gray-300"></label>
            </div>

            <div class="mb-10">
                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Product image</label>
                @if (!string.IsNullOrEmpty(Model.CurrentImagePath))
                {
                    <div class="mb-4">
                        <p class="text-xs text-gray-500 dark:text-gray-400 mb-2">Current image</p>
                        <img src="@Model.CurrentImagePath" alt="" class="max-h-48 max-w-full rounded-2xl border border-gray-200 dark:border-gray-700 object-contain bg-gray-50 dark:bg-gray-800" />
                    </div>
                }
                <label asp-for="ImageFile" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2"></label>

                <input type="file" asp-for="ImageFile" accept=".jpg,.jpeg,.png,.webp,image/jpeg,image/png,image/webp"
                       class="w-full px-5 py-4 border border-gray-300 dark:border-gray-600 rounded-2xl focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 bg-transparent text-gray-900 dark:text-white file:mr-4 file:py-2 file:px-4 file:rounded-xl file:border-0 file:text-sm file:font-medium file:bg-blue-50 file:text-blue-700 dark:file:bg-blue-950 dark:file:text-blue-300" />
                <p class="text-xs text-gray-500 dark:text-gray-400 mt-2">Optional — leave empty to keep the current image. JPG, PNG, or WebP. Max 5 MB.</p>
            </div>

            <div class="flex gap-4">
                <button type="submit"
                        class="flex-1 bg-blue-600 hover:bg-blue-700 text-white font-medium py-4 rounded-2xl transition-colors">
                    Save Changes
                </button>

                <a asp-action="Index"
                   class="flex-1 text-center border border-gray-300 dark:border-gray-600 hover:bg-gray-100 dark:hover:bg-gray-800 font-medium py-4 rounded-2xl transition-colors">
                    Cancel
                </a>
            </div>

        </form>
    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
