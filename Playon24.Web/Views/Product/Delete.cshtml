@using Playon24.PresentationLayer.Modules.Products.ViewModels
@{
    ViewData["Title"] = "Delete Product";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@model ProductEditViewModel

<div class="max-w-md mx-auto p-6">

    <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-3xl p-8">

        <h1 class="text-2xl font-semibold text-gray-900 dark:text-white mb-6 text-center">
            Delete Product
        </h1>

        <p class="text-gray-600 dark:text-gray-400 text-center mb-8">
            Are you sure you want to delete
            <span class="font-medium text-gray-900 dark:text-white">"@Model.ProductName"</span>
            <span class="block text-sm mt-2">Stock: @Model.StockQuantity</span>?
        </p>

        <form asp-action="DeleteConfirmed" asp-route-id="@Model.Id" method="post">
            <div class="flex gap-4">
                <button type="submit"
                        class="flex-1 bg-red-600 hover:bg-red-700 text-white font-medium py-3.5 rounded-2xl transition-colors">
                    Yes, Delete
                </button>

                <a asp-action="Index"
                   class="flex-1 text-center border border-gray-300 dark:border-gray-600 hover:bg-gray-100 dark:hover:bg-gray-800 font-medium py-3.5 rounded-2xl transition-colors">
                    Cancel
                </a>
            </div>
        </form>

    </div>

</div>
