@using Playon24.Web.Controllers
@using Playon24.PresentationLayer.Modules.Products.ViewModels

@{
    ViewData["Title"] = "Products";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@model IReadOnlyList<ProductListViewModel>

<div class="p-6">

    <!-- Header -->
    <div class="flex justify-between items-center mb-6">
        <div>
            <h2 class="text-2xl font-semibold text-gray-900 dark:text-white">All Products</h2>
            <p class="text-gray-500 dark:text-gray-400 text-sm mt-1">
                Total Products: <span class="font-medium">@Model.Count</span>
            </p>
        </div>

        <a asp-action="@nameof(ProductController.Create)"
           class="flex items-center gap-2 bg-blue-600 hover:bg-blue-700 text-white px-5 py-2.5 rounded-xl text-sm font-medium transition">
            <i class="fas fa-plus"></i>
            <span>New Product</span>
        </a>
    </div>

    <!-- Table -->
    <div class="overflow-x-auto bg-white dark:bg-gray-900 rounded-2xl border border-gray-200 dark:border-gray-700 shadow-sm">
        <table class="min-w-full text-sm text-left text-gray-600 dark:text-gray-300">

            <!-- Table Head -->
            <thead class="bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-200 uppercase text-xs">
                <tr>
                    <th class="px-6 py-3">Image</th>
                    <th class="px-6 py-3">Name</th>
                    <th class="px-6 py-3">Stock</th>
                    <th class="px-6 py-3">Price</th>
                    <th class="px-6 py-3">Status</th>
                    <th class="px-6 py-3 text-center">Actions</th>
                </tr>
            </thead>

            <!-- Table Body -->
            <tbody>

                @if (Model.Any())
                {
                    foreach (var product in Model)
                    {
                        <tr class="border-b border-gray-200 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-800 transition">

                            <!-- Image -->
                            <td class="px-6 py-4">
                                @if (!string.IsNullOrEmpty(product.ImagePath))
                                {
                                    <img src="@product.ImagePath"
                                         alt="@product.ProductName"
                                         class="w-10 h-10 rounded-lg object-cover border" />
                                }
                                else
                                {
                                    <div class="w-10 h-10 bg-gray-200 dark:bg-gray-700 rounded-lg flex items-center justify-center">
                                        <i class="fas fa-box text-gray-500"></i>
                                    </div>
                                }
                            </td>

                            <!-- Name -->
                            <td class="px-6 py-4">
                                <p class="font-medium text-gray-900 dark:text-white">
                                    @product.ProductName
                                </p>

                                @if (!string.IsNullOrEmpty(product.Description))
                                {
                                    <p class="text-xs text-gray-500 dark:text-gray-400 line-clamp-1">
                                        @product.Description
                                    </p>
                                }
                            </td>

                            <!-- Stock -->
                            <td class="px-6 py-4 font-medium">
                                @product.StockQuantity
                            </td>

                            <!-- Price -->
                            <td class="px-6 py-4 font-semibold text-gray-900 dark:text-white">
                                @product.UnitPrice.ToString("C")
                            </td>

                            <!-- Status -->
                            <td class="px-6 py-4">
                                @if (product.IsActive)
                                {
                                    <span class="px-3 py-1 text-xs rounded-full bg-green-100 text-green-600 dark:bg-green-900/30 dark:text-green-400">
                                        Active
                                    </span>
                                }
                                else
                                {
                                    <span class="px-3 py-1 text-xs rounded-full bg-red-100 text-red-600 dark:bg-red-900/30 dark:text-red-400">
                                        Inactive
                                    </span>
                                }
                            </td>

                            <!-- Actions -->
                            <td class="px-6 py-4 text-center">
                                <div class="flex justify-center gap-2">

                                    <!-- View -->
                                    <a asp-action="@nameof(ProductController.Details)"
                                       asp-route-id="@product.Id"
                                       class="flex items-center gap-1 px-3 py-1.5 text-xs font-medium text-blue-600 bg-blue-100 hover:bg-blue-200 dark:bg-blue-900/30 dark:text-blue-400 rounded-lg transition">
                                        <i class="fas fa-eye"></i>
                                        View
                                    </a>

                                    <!-- Edit -->
                                    <a asp-action="@nameof(ProductController.Update)"
                                       asp-route-id="@product.Id"
                                       class="flex items-center gap-1 px-3 py-1.5 text-xs font-medium text-yellow-600 bg-yellow-100 hover:bg-yellow-200 dark:bg-yellow-900/30 dark:text-yellow-400 rounded-lg transition">
                                        <i class="fas fa-edit"></i>
                                        Edit
                                    </a>

                                    <!-- Delete -->
                                    <a asp-action="@nameof(ProductController.Delete)"
                                       asp-route-id="@product.Id"
                                       class="flex items-center gap-1 px-3 py-1.5 text-xs font-medium text-red-600 bg-red-100 hover:bg-red-200 dark:bg-red-900/30 dark:text-red-400 rounded-lg transition">
                                        <i class="fas fa-trash"></i>
                                        Delete
                                    </a>

                                </div>
                            </td>

                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center py-12 text-gray-500 dark:text-gray-400">
                            <i class="fas fa-box-open text-4xl mb-3"></i>
                            <p>No products found</p>
                        </td>
                    </tr>
                }

            </tbody>
        </table>
    </div>

</div>