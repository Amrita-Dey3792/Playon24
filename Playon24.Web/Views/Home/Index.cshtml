@using Playon24.Web.Controllers
@model DashboardSummaryViewModel
@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="max-w-7xl mx-auto space-y-8">
    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4">
        <div>
            <h1 class="text-2xl font-semibold text-gray-900 dark:text-white">Dashboard</h1>
        </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-4 md:gap-6">
        <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-3xl p-6 shadow-sm">
            <div class="flex items-center justify-between gap-3">
                <div>
                    <p class="text-xs font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400">Products</p>
                    <p class="text-3xl font-bold text-gray-900 dark:text-white mt-1">@Model.TotalProducts</p>
                    <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">@Model.ActiveProducts active</p>
                </div>
                <div class="w-14 h-14 rounded-2xl bg-blue-100 dark:bg-blue-950/50 flex items-center justify-center">
                    <i class="fas fa-box text-2xl text-blue-600 dark:text-blue-400"></i>
                </div>
            </div>
            <a asp-controller="Product" asp-action="Index" class="inline-block mt-4 text-sm font-medium text-blue-600 dark:text-blue-400 hover:underline">Manage products</a>
        </div>

        <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-3xl p-6 shadow-sm">
            <div class="flex items-center justify-between gap-3">
                <div>
                    <p class="text-xs font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400">Low stock</p>
                    <p class="text-3xl font-bold @(Model.LowStockProducts > 0 ? "text-amber-600 dark:text-amber-400" : "text-gray-900 dark:text-white") mt-1">@Model.LowStockProducts</p>
                    <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Active items ≤ @Model.LowStockThreshold units</p>
                </div>
                <div class="w-14 h-14 rounded-2xl bg-amber-100 dark:bg-amber-950/50 flex items-center justify-center">
                    <i class="fas fa-exclamation-triangle text-2xl text-amber-600 dark:text-amber-400"></i>
                </div>
            </div>
            <a asp-controller="Product" asp-action="Index" class="inline-block mt-4 text-sm font-medium text-blue-600 dark:text-blue-400 hover:underline">Review inventory</a>
        </div>

        <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-3xl p-6 shadow-sm">
            <div class="flex items-center justify-between gap-3">
                <div>
                    <p class="text-xs font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400">Customers</p>
                    <p class="text-3xl font-bold text-gray-900 dark:text-white mt-1">@Model.TotalCustomers</p>
                    <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Registered profiles</p>
                </div>
                <div class="w-14 h-14 rounded-2xl bg-violet-100 dark:bg-violet-950/50 flex items-center justify-center">
                    <i class="fas fa-users text-2xl text-violet-600 dark:text-violet-400"></i>
                </div>
            </div>
            <a asp-controller="Customer" asp-action="Index" class="inline-block mt-4 text-sm font-medium text-blue-600 dark:text-blue-400 hover:underline">View customers</a>
        </div>

        <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-3xl p-6 shadow-sm">
            <div class="flex items-center justify-between gap-3">
                <div>
                    <p class="text-xs font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400">Invoices</p>
                    <p class="text-3xl font-bold text-gray-900 dark:text-white mt-1">@Model.TotalInvoices</p>
                    <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Revenue @Model.InvoiceRevenueTotal.ToString("C")</p>
                </div>
                <div class="w-14 h-14 rounded-2xl bg-emerald-100 dark:bg-emerald-950/50 flex items-center justify-center">
                    <i class="fas fa-file-invoice-dollar text-2xl text-emerald-600 dark:text-emerald-400"></i>
                </div>
            </div>
            <a asp-controller="Invoice" asp-action="Index" class="inline-block mt-4 text-sm font-medium text-blue-600 dark:text-blue-400 hover:underline">All invoices</a>
        </div>
    </div>

    <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-3xl shadow-sm overflow-hidden">
        <div class="px-6 py-5 border-b border-gray-200 dark:border-gray-700 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
            <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Recent invoices</h2>
            <a asp-controller="Invoice" asp-action="Sell"
               class="inline-flex items-center justify-center gap-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium px-4 py-2 rounded-2xl w-fit">
                <i class="fas fa-plus"></i> New sale
            </a>
        </div>
        <div class="overflow-x-auto">
            <table class="min-w-full text-sm">
                <thead class="bg-gray-50 dark:bg-gray-800 text-left text-gray-600 dark:text-gray-300">
                    <tr>
                        <th class="px-6 py-3 font-medium">Invoice</th>
                        <th class="px-6 py-3 font-medium">Customer</th>
                        <th class="px-6 py-3 font-medium">Date</th>
                        <th class="px-6 py-3 font-medium text-right">Total</th>
                        <th class="px-6 py-3 font-medium">Status</th>
                        <th class="px-6 py-3 font-medium text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
                    @if (Model.RecentInvoices.Count == 0)
                    {
                        <tr>
                            <td colspan="6" class="px-6 py-12 text-center text-gray-500 dark:text-gray-400">
                                No invoices yet. <a asp-controller="Invoice" asp-action="Sell" class="text-blue-600 dark:text-blue-400 font-medium">Create the first sale</a>.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var row in Model.RecentInvoices)
                        {
                            <tr class="hover:bg-gray-50 dark:hover:bg-gray-800/40">
                                <td class="px-6 py-3 font-medium text-gray-900 dark:text-white">@row.InvoiceNumber</td>
                                <td class="px-6 py-3">@row.CustomerName</td>
                                <td class="px-6 py-3 text-gray-600 dark:text-gray-300">@row.CreatedAt.ToLocalTime().ToString("g")</td>
                                <td class="px-6 py-3 text-right font-semibold">@row.GrandTotal.ToString("C")</td>
                                <td class="px-6 py-3">
                                    <span class="inline-flex px-2.5 py-1 rounded-full text-xs font-medium bg-gray-100 dark:bg-gray-800 text-gray-800 dark:text-gray-200">@row.PaymentStatus</span>
                                </td>
                                <td class="px-6 py-3 text-right whitespace-nowrap">
                                    <a asp-controller="Invoice" asp-action="Details" asp-route-id="@row.InvoiceId" class="text-blue-600 dark:text-blue-400 font-medium mr-3">Details</a>
                                    <a asp-controller="Invoice" asp-action="ReportPdf" asp-route-id="@row.InvoiceId" target="_blank" class="text-blue-600 dark:text-blue-400 font-medium">PDF</a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
