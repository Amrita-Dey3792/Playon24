@using Playon24.Web.Controllers
@using Playon24.PresentationLayer.Modules.Invoices.ViewModels
@model InvoiceListPageViewModel
@{
    ViewData["Title"] = "Invoices";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="p-3 md:p-6 max-w-6xl mx-auto">
    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-8">
        <div>
            <h1 class="text-2xl font-semibold text-gray-900 dark:text-white">Invoices</h1>
        </div>
        <a asp-action="@nameof(InvoiceController.Sell)"
           class="inline-flex items-center justify-center gap-2 bg-blue-600 hover:bg-blue-700 text-white px-5 py-2.5 rounded-2xl text-sm font-medium transition-colors">
            <i class="fas fa-file-invoice"></i>
            New sale
        </a>
    </div>

    <form method="get" asp-action="@nameof(InvoiceController.Index)"
          class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-3xl p-5 md:p-6 mb-8 flex flex-col md:flex-row flex-wrap gap-4 items-end">
        <div class="flex-1 min-w-[200px]">
            <label class="block text-xs font-medium text-gray-500 dark:text-gray-400 mb-1" for="customerId">Customer</label>
            <select name="customerId" id="customerId"
                    class="w-full px-4 py-2.5 rounded-2xl border border-gray-300 dark:border-gray-600 bg-transparent dark:text-white">
                <option value="">All customers</option>
                @foreach (var c in Model.CustomerOptions)
                {
                    if (Model.FilterCustomerId == c.Id)
                    {
                        <option value="@c.Id" selected>@c.DisplayName</option>
                    }
                    else
                    {
                        <option value="@c.Id">@c.DisplayName</option>
                    }
                }
            </select>
        </div>
        <div class="flex-1 min-w-[200px]">
            <label class="block text-xs font-medium text-gray-500 dark:text-gray-400 mb-1" for="search">Search</label>
            <input type="text" name="search" id="search" value="@Model.Search"
                   placeholder="Invoice #, name, email…"
                   class="w-full px-4 py-2.5 rounded-2xl border border-gray-300 dark:border-gray-600 bg-transparent dark:text-white" />
        </div>
        <div class="flex gap-2">
            <button type="submit"
                    class="bg-gray-900 dark:bg-gray-100 dark:text-gray-900 text-white px-6 py-2.5 rounded-2xl text-sm font-medium transition-colors hover:bg-gray-700 dark:hover:bg-gray-300">
                Apply
            </button>
            <a asp-action="@nameof(InvoiceController.Index)"
               class="px-6 py-2.5 rounded-2xl border border-gray-300 dark:border-gray-600 text-sm font-medium hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors">
                Clear
            </a>
        </div>
    </form>

    <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-3xl overflow-hidden shadow-sm">
        <div class="overflow-x-auto">
            <table class="min-w-full text-sm">
                <thead class="bg-gray-50 dark:bg-gray-800 text-left text-gray-600 dark:text-gray-300">
                    <tr>
                        <th class="px-5 py-3 font-medium">Invoice #</th>
                        <th class="px-5 py-3 font-medium">Customer</th>
                        <th class="px-5 py-3 font-medium">Date</th>
                        <th class="px-5 py-3 font-medium text-right">Total</th>
                        <th class="px-5 py-3 font-medium">Status</th>
                        <th class="px-5 py-3 font-medium text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
                    @if (Model.Invoices.Count == 0)
                    {
                        <tr>
                            <td colspan="6" class="px-5 py-10 text-center text-gray-500 dark:text-gray-400">
                                No invoices match your filters.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var row in Model.Invoices)
                        {
                            
                                var badgeBg = row.PaymentStatus?.ToLower() switch
                                {
                                    "paid"    => "bg-emerald-100 text-emerald-800 dark:bg-emerald-900/40 dark:text-emerald-300",
                                    "pending" => "bg-amber-100 text-amber-800 dark:bg-amber-900/40 dark:text-amber-300",
                                    "overdue" => "bg-red-100 text-red-800 dark:bg-red-900/40 dark:text-red-300",
                                    _         => "bg-gray-100 text-gray-700 dark:bg-gray-800 dark:text-gray-300"
                                };
                           
                            <tr class="hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors">
                                <td class="px-5 py-3 font-medium text-gray-900 dark:text-white">
                                    @row.InvoiceNumber
                                </td>
                                <td class="px-5 py-3 text-gray-700 dark:text-gray-300">
                                    @row.CustomerName
                                </td>
                                <td class="px-5 py-3 text-gray-500 dark:text-gray-400">
                                    @row.CreatedAt.ToLocalTime().ToString("g")
                                </td>
                                <td class="px-5 py-3 text-right font-semibold text-gray-900 dark:text-white">
                                    @row.GrandTotal.ToString("C")
                                </td>
                                <td class="px-5 py-3">
                                    <span class="inline-flex px-2.5 py-1 rounded-full text-xs font-medium @badgeBg">
                                        @row.PaymentStatus
                                    </span>
                                </td>
                                <td class="px-5 py-3 text-right whitespace-nowrap">
                                    <a asp-action="@nameof(InvoiceController.Details)" asp-route-id="@row.InvoiceId"
                                       class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-xl text-xs font-medium
                                              text-gray-700 dark:text-gray-300 bg-gray-100 dark:bg-gray-800
                                              hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors mr-2">
                                        <i class="fas fa-eye"></i>
                                        Details
                                    </a>
                                    <a asp-action="@nameof(InvoiceController.ReportPdf)" asp-route-id="@row.InvoiceId"
                                       target="_blank"
                                       class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-xl text-xs font-medium
                                              text-red-700 dark:text-red-400 bg-red-50 dark:bg-red-900/30
                                              hover:bg-red-100 dark:hover:bg-red-900/50 transition-colors">
                                        <i class="fas fa-file-pdf"></i>
                                        PDF
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>