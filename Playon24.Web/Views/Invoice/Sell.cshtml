@using Playon24.Web.Controllers
@using Playon24.PresentationLayer.Modules.Invoices.ViewModels
@model InvoiceSellViewModel
@{
    ViewData["Title"] = "New invoice";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="max-w-5xl mx-auto p-3 md:p-6">
    <div class="mb-8">
        <h1 class="text-2xl font-semibold text-gray-900 dark:text-white">Create invoice</h1>
    </div>

    <form asp-action="@nameof(InvoiceController.Sell)" method="post" id="sell-form"
          class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-3xl p-6 md:p-8 shadow-sm space-y-8">

        <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm"></div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
                <label asp-for="CustomerId" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2"></label>
                <select asp-for="CustomerId" class="w-full px-4 py-3 rounded-2xl border border-gray-300 dark:border-gray-600 bg-transparent dark:text-white">
                    <option value="0">— Select customer —</option>
                    @foreach (var c in Model.CustomerOptions)
                    {
                        <option value="@c.Id">@c.DisplayName</option>
                    }
                </select>
                <span asp-validation-for="CustomerId" class="text-red-500 text-sm"></span>
            </div>
            <div>
                <label asp-for="PaymentStatus" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2"></label>
                <input asp-for="PaymentStatus" class="w-full px-4 py-3 rounded-2xl border border-gray-300 dark:border-gray-600 bg-transparent dark:text-white" />
            </div>
            <div>
                <label asp-for="DiscountAmount" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2"></label>
                <input asp-for="DiscountAmount" class="w-full px-4 py-3 rounded-2xl border border-gray-300 dark:border-gray-600 bg-transparent dark:text-white" />
            </div>
            <div>
                <label asp-for="TaxAmount" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2"></label>
                <input asp-for="TaxAmount" class="w-full px-4 py-3 rounded-2xl border border-gray-300 dark:border-gray-600 bg-transparent dark:text-white" />
            </div>
        </div>

        <div>
            <h2 class="text-lg font-medium text-gray-900 dark:text-white mb-4">Line items</h2>

            <div class="overflow-x-auto rounded-2xl border border-gray-200 dark:border-gray-700">
                <table class="min-w-full text-sm">
                    <thead class="bg-gray-50 dark:bg-gray-800 text-left text-gray-600 dark:text-gray-300">
                        <tr>
                            <th class="px-4 py-3 font-medium">Product</th>
                            <th class="px-4 py-3 font-medium w-28">Qty</th>
                            <th class="px-4 py-3 font-medium w-32">Disc %</th>
                            <th class="px-4 py-3 w-12"></th>
                        </tr>
                    </thead>
                    <tbody id="lines-body">

                    </tbody>
                </table>
            </div>

            <button type="button" onclick="addLine()"
                    class="mt-3 inline-flex items-center gap-2 px-4 py-2 rounded-xl border border-dashed border-gray-300 dark:border-gray-600 text-sm text-gray-500 hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors">
                + Add product
            </button>

            <span id="lines-error" class="text-red-500 text-sm mt-2 block"></span>
        </div>

        <div class="flex flex-wrap gap-4 pt-4 border-t border-gray-200 dark:border-gray-700">
            <button type="submit"
                    class="bg-blue-600 hover:bg-blue-700 text-white font-medium px-8 py-3 rounded-2xl transition-all active:scale-95">
                Create invoice &amp; PDF
            </button>
            <a asp-action="@nameof(InvoiceController.Index)"
               class="inline-flex items-center px-8 py-3 rounded-2xl border border-gray-300 dark:border-gray-600 font-medium hover:bg-gray-50 dark:hover:bg-gray-800">
                Cancel
            </a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        const PRODUCTS = [
            { id: 0, label: '— Skip row —' },
            @foreach (var p in Model.ProductOptions)
            {
                @:{ id: @p.Id, label: @Json.Serialize(p.DisplayName) },
            }
        ];

        const SERVER_LINES = @Json.Serialize(Model.Lines.Select(l => new {
            productId   = l.ProductId,
            quantity    = l.Quantity,
            discountPct = l.DiscountPercent
        }));

        let rowIndex = 0;

        function buildProductOptions(selectedId) {
            return PRODUCTS.map(p =>
                `<option value="${p.id}" ${p.id === selectedId ? 'selected' : ''}>${p.label}</option>`
            ).join('');
        }

        function addLine(productId = 0, quantity = 1, discountPct = 0) {
            const i = rowIndex++;
            const tr = document.createElement('tr');
            tr.className = 'align-top';
            tr.dataset.index = i;
            tr.innerHTML = `
                <td class="px-4 py-3">
                    <select name="Lines[${i}].ProductId"
                            class="w-full min-w-[220px] px-3 py-2 rounded-xl border border-gray-300 dark:border-gray-600 bg-transparent dark:text-white"
                            onchange="validateRow(this.closest('tr')); clearLinesError()">
                        ${buildProductOptions(productId)}
                    </select>
                    <span class="row-error text-red-500 text-xs hidden"></span>
                </td>
                <td class="px-4 py-3">
                    <input type="number" name="Lines[${i}].Quantity" value="${quantity}" min="1"
                           class="w-full px-3 py-2 rounded-xl border border-gray-300 dark:border-gray-600 bg-transparent dark:text-white"
                           oninput="validateRow(this.closest('tr')); clearLinesError()" />
                </td>
                <td class="px-4 py-3">
                    <input type="number" name="Lines[${i}].DiscountPercent" value="${discountPct}"
                           min="0" max="100" step="0.01"
                           class="w-full px-3 py-2 rounded-xl border border-gray-300 dark:border-gray-600 bg-transparent dark:text-white"
                           oninput="validateRow(this.closest('tr'))" />
                </td>
                <td class="px-4 py-3 text-center">
                    <button type="button" onclick="removeLine(this)"
                            class="text-gray-400 hover:text-red-500 transition-colors px-2 py-1 rounded-lg text-lg leading-none"
                            title="Remove row">✕</button>
                </td>`;
            document.getElementById('lines-body').appendChild(tr);
        }

        function removeLine(btn) {
            const tbody = document.getElementById('lines-body');
            if (tbody.rows.length <= 1) return;
            btn.closest('tr').remove();
            reindex();
            clearLinesError();
        }

        function reindex() {
            document.querySelectorAll('#lines-body tr').forEach((tr, i) => {
                tr.querySelectorAll('[name]').forEach(el => {
                    el.name = el.name.replace(/Lines\[\d+\]/, `Lines[${i}]`);
                });
            });
            rowIndex = document.querySelectorAll('#lines-body tr').length;
        }

     
        function validateRow(tr) {
    const select    = tr.querySelector('select');
    const qtyInput  = tr.querySelector('input[name$=".Quantity"]');
    const discInput = tr.querySelector('input[name$=".DiscountPercent"]');
    const errorSpan = tr.querySelector('.row-error');

    const productId = parseInt(select.value);
    const qty       = parseFloat(qtyInput.value);
    const disc      = parseFloat(discInput.value);

    const productErr = productId === 0;
    const qtyErr     = !qty || qty < 1;
    const discErr    = isNaN(disc) || disc < 0 || disc > 100;

    setFieldError(select,   productErr);
    setFieldError(qtyInput, qtyErr);
    setFieldError(discInput,discErr);

    const msg = productErr ? 'Select a product.'
              : qtyErr     ? 'Quantity must be at least 1.'
              : discErr    ? 'Discount must be 0–100.'
              : '';

    errorSpan.textContent = msg;
    errorSpan.classList.toggle('hidden', !msg);

    return msg === '';
}

        function setFieldError(el, hasError) {
            el.classList.toggle('border-red-500', hasError);
            el.classList.toggle('dark:border-red-400', hasError);
            el.classList.toggle('border-gray-300', !hasError);
            el.classList.toggle('dark:border-gray-600', !hasError);
        }


        function hasAnyActive() {
            return [...document.querySelectorAll('#lines-body select')]
                .some(s => parseInt(s.value) > 0);
        }

       
        function validateLines() {
            const rows = [...document.querySelectorAll('#lines-body tr')];


            let rowsValid = rows.every(tr => validateRow(tr));

          
            const activeCount = rows.filter(tr =>
                parseInt(tr.querySelector('select').value) > 0 &&
                parseFloat(tr.querySelector('input[name$=".Quantity"]').value) >= 1
            ).length;

            if (activeCount === 0) {
                document.getElementById('lines-error').textContent =
                    'Add at least one product line.';
                return false;
            }

            if (!rowsValid) {
                
                return false;
            }

            document.getElementById('lines-error').textContent = '';
            return true;
        }

        function clearLinesError() {
            document.getElementById('lines-error').textContent = '';
        }

        document.getElementById('sell-form').addEventListener('submit', function (e) {
    e.preventDefault(); 

    const linesOk = validateLines();
    const headerOk = $(this).valid(); 

    if (linesOk && headerOk) {
        this.submit();
    }
});

      
        const initLines = SERVER_LINES.length > 0
            ? SERVER_LINES
            : Array(3).fill({});
        initLines.forEach(l => addLine(l.productId ?? 0, l.quantity ?? 1, l.discountPct ?? 0));
    </script>
}