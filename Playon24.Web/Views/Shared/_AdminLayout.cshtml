@using Playon24.Web.Controllers
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en" class="light">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Shopify Admin - @ViewBag.Title</title>

    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Open+Sans:ital,wght@0,300..800;1,300..800&display=swap" rel="stylesheet">

    <script>
        tailwind.config = {
            darkMode: 'class',
        }
    </script>

    <style>
        body {
            font-family: "Open Sans", system-ui, sans-serif;
        }

        .sidebar {
            transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .sidebar-link {
            transition: all 0.3s ease;
        }

            .sidebar-link:hover {
                transform: translateX(8px);
            }

        .active {
            background-color: #3b82f6;
            color: white !important;
            border-radius: 12px;
        }

        .sidebar-nav::-webkit-scrollbar {
            display: none;
        }
    </style>

    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="bg-gray-50 dark:bg-gray-950 text-gray-900 dark:text-gray-100">
    <div class="flex h-screen overflow-hidden">
        <div id="sidebar"
             class="sidebar fixed lg:static inset-y-0 left-0 z-50 w-72 bg-white dark:bg-gray-900 border-r border-gray-200 dark:border-gray-800 flex flex-col transform -translate-x-full lg:translate-x-0">

            <div class="px-6 py-7 flex items-center gap-3">
                <div class="w-10 h-10 bg-blue-600 rounded-2xl flex items-center justify-center text-white font-bold text-3xl shadow-lg">
                    C
                </div>
                <div>
                    <h1 class="text-2xl font-bold tracking-tight">Playon24</h1>
                    <p class="text-xs text-gray-500 dark:text-gray-400">Admin Dashboard</p>
                </div>
                <button type="button" onclick="toggleSidebar()"
                        class="lg:hidden ml-auto text-gray-500 hover:text-gray-700 dark:hover:text-gray-300">
                    <i class="fas fa-times text-2xl"></i>
                </button>
            </div>

            <div class="px-6 py-5">
                <div class="relative">
                    <input type="text" id="searchInput"
                           placeholder="Search products, orders..."
                           class="search-input w-full bg-gray-100 dark:bg-gray-800 border border-transparent focus:border-blue-500 rounded-3xl py-3.5 px-6 pl-14 text-sm focus:outline-none" />
                    <i class="fas fa-search absolute left-6 top-1/2 -translate-y-1/2 text-gray-400"></i>
                </div>
            </div>

            <nav class="flex-1 px-4 overflow-y-auto sidebar-nav">
                <ul class="space-y-1 pb-8" id="sidebar-menu">
                    <li>
                        <a asp-controller="Home" asp-action="Index" class="sidebar-link flex items-center gap-4 px-6 py-4 text-sm font-medium">
                            <i class="fas fa-home w-5"></i><span>Dashboard</span>
                        </a>
                    </li>
                 
                    <li>
                        <a asp-controller="Product" asp-action="Index" class="sidebar-link flex items-center gap-4 px-6 py-4 text-sm font-medium">
                            <i class="fas fa-box w-5"></i><span>Products</span>
                        </a>
                    </li>
                    <li>
                        <a asp-controller="Invoice" asp-action="Index" class="sidebar-link flex items-center gap-4 px-6 py-4 text-sm font-medium">
                            <i class="fas fa-file-invoice w-5"></i><span>Invoices</span>
                        </a>
                    </li>
                    <li>
                        <a asp-controller="Customer" asp-action="Index" class="sidebar-link flex items-center gap-4 px-6 py-4 text-sm font-medium">
                            <i class="fas fa-users w-5"></i><span>Customers</span>
                        </a>
                    </li>
                  

                 
                </ul>
            </nav>

            <div class="border-t border-gray-200 dark:border-gray-800 p-4">
                <div onclick="toggleUserMenu()"
                     class="flex items-center gap-3 p-3 hover:bg-gray-100 dark:hover:bg-gray-800 rounded-3xl cursor-pointer transition-colors">
                    <div class="w-11 h-11 bg-gradient-to-br from-purple-500 to-pink-500 rounded-2xl flex items-center justify-center text-white font-bold text-lg ring-2 ring-white dark:ring-gray-900">
                        AD
                    </div>
                    <div class="flex-1 min-w-0">
                        <p class="font-semibold text-sm truncate">Amrita Dey</p>
                        <p class="text-xs text-gray-500 dark:text-gray-400">Administrator</p>
                    </div>
                    <i class="fas fa-ellipsis-v text-gray-400"></i>
                </div>
            </div>
        </div>

        <div class="flex-1 flex flex-col min-w-0 overflow-hidden">
            <nav class="bg-white dark:bg-gray-900 border-b border-gray-200 dark:border-gray-800 px-4 sm:px-8 py-5 flex items-center justify-between">
                <div class="flex items-center gap-4">
                    <button type="button" onclick="toggleSidebar()"
                            class="lg:hidden p-3 -ml-2 text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800 rounded-2xl">
                        <i class="fas fa-bars text-2xl"></i>
                    </button>
                    <div class="hidden sm:block">
                        <h1 class="text-xl font-semibold">Admin Dashboard</h1>
                    </div>
                </div>

                <div class="flex items-center gap-3 sm:gap-4">
                    <button type="button" onclick="toggleTheme()"
                            class="w-11 h-11 flex items-center justify-center rounded-2xl hover:bg-gray-100 dark:hover:bg-gray-800 transition-all">
                        <i id="themeIcon" class="fas fa-moon text-xl"></i>
                    </button>

                    <button type="button" onclick="toggleNotifications()"
                            class="relative w-11 h-11 flex items-center justify-center rounded-2xl hover:bg-gray-100 dark:hover:bg-gray-800 transition-all">
                        <i class="fas fa-bell text-xl"></i>
                        <span class="absolute -top-1 right-1 w-5 h-5 bg-red-500 text-white text-[10px] font-medium flex items-center justify-center rounded-full">7</span>
                    </button>

                    <a asp-controller="Product" asp-action="Create" class="hidden sm:flex items-center gap-2 bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-3xl text-sm font-semibold transition-all active:scale-95 shadow-md">
                        <i class="fas fa-plus"></i>
                        <span>New Product</span>
                    </a>

                    <div onclick="toggleProfileMenu()"
                         class="flex items-center gap-3 cursor-pointer pl-3 border-l border-gray-200 dark:border-gray-700">
                        <div class="text-right hidden sm:block">
                            <p class="text-sm font-medium">Amrita Dey</p>
                            <p class="text-xs text-emerald-500">● Online</p>
                        </div>
                        <div class="w-9 h-9 bg-gradient-to-br from-purple-500 to-pink-500 rounded-2xl flex items-center justify-center text-white font-bold ring-2 ring-white dark:ring-gray-900">
                            AD
                        </div>
                    </div>
                </div>
            </nav>

            <div class="flex-1 overflow-auto p-4 sm:p-8">
                @RenderBody()
            </div>
        </div>
    </div>

    <script>
        function setActiveMenu() {
            const currentPath = window.location.pathname.toLowerCase();

            document.querySelectorAll('.sidebar-link').forEach(link => {
                link.classList.remove('active');

                const linkHref = link.getAttribute('href')?.toLowerCase();
                const aspAction = link.getAttribute('asp-action');
                const aspController = link.getAttribute('asp-controller');

                let isActive = false;

                if (linkHref && linkHref !== '#') {
                    if (currentPath === '/' && linkHref === '/') isActive = true;
                    else if (currentPath.includes(linkHref) && linkHref !== '/') isActive = true;
                }

                if (aspController && aspAction) {
                    const expectedPath = `/${aspController.toLowerCase()}/${aspAction.toLowerCase()}`;
                    if (currentPath.startsWith(expectedPath)) isActive = true;
                }

                if (isActive) {
                    link.classList.add('active');
                }
            });
        }

        function toggleSidebar() {
            const sidebar = document.getElementById('sidebar');
            sidebar.classList.toggle('-translate-x-full');
        }

        function toggleTheme() {
            document.documentElement.classList.toggle('dark');
            const icon = document.getElementById('themeIcon');
            icon.classList.toggle('fa-moon');
            icon.classList.toggle('fa-sun');
        }

        function toggleUserMenu() { alert("User menu: Profile, Settings, Logout"); }
        function toggleNotifications() { alert("Notifications panel"); }
        function toggleProfileMenu() { alert("Profile dropdown"); }

        document.addEventListener('keydown', (e) => {
            if (e.key === '/' && document.getElementById('searchInput') !== document.activeElement) {
                e.preventDefault();
                document.getElementById('searchInput').focus();
            }
        });

        document.addEventListener('click', (e) => {
            const t = e.target;
            if (!(t instanceof Element)) return;
            const sidebar = document.getElementById('sidebar');
            if (window.innerWidth < 1024 &&
                !sidebar.contains(t) &&
                !t.closest('button[onclick="toggleSidebar()"]')) {
                sidebar.classList.add('-translate-x-full');
            }
        });

        window.addEventListener('load', setActiveMenu);
        window.addEventListener('popstate', setActiveMenu);
    </script>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
