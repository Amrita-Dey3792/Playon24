<!DOCTYPE html>
<html lang="en" class="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Playon24.Web</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css" rel="stylesheet">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Open+Sans:ital,wght@0,300..800;1,300..800&display=swap" rel="stylesheet">
    <script>
        tailwind.config = {
          content: [],
          darkMode: 'class',
        }
    </script>
    <style>
        body {
            font-family: "Open Sans", sans-serif;
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="min-h-screen flex flex-col bg-gray-50 dark:bg-gray-950 text-gray-900 dark:text-gray-100">

    <header class="sticky top-0 z-50 bg-white dark:bg-gray-900 border-b border-gray-200 dark:border-gray-800">
        <div class="max-w-7xl mx-auto px-4 sm:px-8 py-5 flex items-center justify-between gap-4">
            <div class="flex items-center gap-4 min-w-0">
                <details class="lg:hidden relative">
                    <summary class="list-none cursor-pointer p-3 -ml-2 text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800 rounded-2xl [&::-webkit-details-marker]:hidden" aria-label="Open menu">
                        <i class="fas fa-bars text-2xl"></i>
                    </summary>
                    <ul class="absolute left-0 z-[60] mt-2 p-2 shadow-lg bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-3xl w-52 space-y-1">
                        <li><a asp-area="" asp-controller="Home" asp-action="Landing" class="block px-4 py-3 rounded-2xl text-sm font-medium hover:bg-gray-100 dark:hover:bg-gray-800">Home</a></li>
                        <li><a asp-area="" asp-controller="Home" asp-action="Privacy" class="block px-4 py-3 rounded-2xl text-sm font-medium hover:bg-gray-100 dark:hover:bg-gray-800">Privacy</a></li>
                        <li><a asp-area="" asp-controller="Product" asp-action="Index" class="block px-4 py-3 rounded-2xl text-sm font-medium hover:bg-gray-100 dark:hover:bg-gray-800">Products</a></li>
                        <li><a asp-area="" asp-controller="Customer" asp-action="Index" class="block px-4 py-3 rounded-2xl text-sm font-medium hover:bg-gray-100 dark:hover:bg-gray-800">Customers</a></li>
                        <li><a asp-area="" asp-controller="Home" asp-action="Index" class="block px-4 py-3 rounded-2xl text-sm font-medium hover:bg-gray-100 dark:hover:bg-gray-800">Dashboard</a></li>
                    </ul>
                </details>
                <a asp-area="" asp-controller="Home" asp-action="Landing" class="flex items-center gap-3 min-w-0">
                    <div class="w-10 h-10 bg-blue-600 rounded-2xl flex items-center justify-center text-white font-bold text-lg shadow-lg shrink-0">
                        C
                    </div>
                    <span class="text-lg sm:text-xl font-bold tracking-tight truncate">CARTIFY</span>
                </a>
            </div>

            <nav class="hidden lg:flex items-center gap-1">
                <a asp-area="" asp-controller="Home" asp-action="Landing" class="px-5 py-3 rounded-2xl text-sm font-medium text-gray-700 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors">Home</a>
                <a asp-area="" asp-controller="Home" asp-action="Privacy" class="px-5 py-3 rounded-2xl text-sm font-medium text-gray-700 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors">Privacy</a>
                <a asp-area="" asp-controller="Product" asp-action="Index" class="px-5 py-3 rounded-2xl text-sm font-medium text-gray-700 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors">Products</a>
                <a asp-area="" asp-controller="Customer" asp-action="Index" class="px-5 py-3 rounded-2xl text-sm font-medium text-gray-700 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors">Customers</a>
                <a asp-area="" asp-controller="Home" asp-action="Index" class="px-5 py-3 rounded-2xl text-sm font-medium text-gray-700 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors">Dashboard</a>
            </nav>

            <div class="flex items-center gap-2 sm:gap-3 shrink-0">
                <button type="button" onclick="toggleTheme()"
                        class="w-11 h-11 flex items-center justify-center rounded-2xl hover:bg-gray-100 dark:hover:bg-gray-800 transition-all"
                        aria-label="Toggle theme">
                    <i id="themeIcon" class="fas fa-moon text-xl text-gray-600 dark:text-gray-300"></i>
                </button>
            </div>
        </div>
    </header>

    <div class="flex-1 w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 sm:py-8">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="border-t border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 mt-auto">
        <div class="max-w-7xl mx-auto px-4 sm:px-8 py-10">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
                <div class="space-y-3">
                    <div class="flex items-center gap-3">
                        <div class="w-10 h-10 bg-blue-600 rounded-2xl flex items-center justify-center text-white font-bold shadow-lg">C</div>
                        <span class="text-lg font-bold tracking-tight">CARTIFY</span>
                    </div>
                    <p class="text-sm text-gray-500 dark:text-gray-400 max-w-xs">Your storefront experience — browse products and manage your account with ease.</p>
                </div>
                <div>
                    <p class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-widest mb-4">Shop</p>
                    <ul class="space-y-2 text-sm">
                        <li><a asp-area="" asp-controller="Home" asp-action="Landing" class="text-gray-700 dark:text-gray-200 hover:text-blue-600 dark:hover:text-blue-400 font-medium">Home</a></li>
                        <li><a asp-area="" asp-controller="Product" asp-action="Index" class="text-gray-700 dark:text-gray-200 hover:text-blue-600 dark:hover:text-blue-400 font-medium">Products</a></li>
                        <li><a asp-area="" asp-controller="Customer" asp-action="Index" class="text-gray-700 dark:text-gray-200 hover:text-blue-600 dark:hover:text-blue-400 font-medium">Customers</a></li>
                        <li><a asp-area="" asp-controller="Home" asp-action="Index" class="text-gray-700 dark:text-gray-200 hover:text-blue-600 dark:hover:text-blue-400 font-medium">Dashboard</a></li>
                    </ul>
                </div>
                <div>
                    <p class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-widest mb-4">Legal</p>
                    <ul class="space-y-2 text-sm">
                        <li><a asp-area="" asp-controller="Home" asp-action="Privacy" class="text-gray-700 dark:text-gray-200 hover:text-blue-600 dark:hover:text-blue-400 font-medium">Privacy policy</a></li>
                    </ul>
                </div>
            </div>
            <div class="mt-10 pt-8 border-t border-gray-200 dark:border-gray-800 flex flex-col sm:flex-row items-center justify-between gap-3 text-sm text-gray-500 dark:text-gray-400">
                <p>&copy; @DateTime.Now.Year Playon24.Web. All rights reserved.</p>
                <p>Built with ASP.NET Core</p>
            </div>
        </div>
    </footer>

    <script>
        function toggleTheme() {
            document.documentElement.classList.toggle('dark');
            const icon = document.getElementById('themeIcon');
            if (icon) {
                icon.classList.toggle('fa-moon');
                icon.classList.toggle('fa-sun');
            }
        }
    </script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
