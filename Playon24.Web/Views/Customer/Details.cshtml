@using Playon24.Web.Controllers
@using Playon24.PresentationLayer.Modules.Customers.ViewModels
@{
    ViewData["Title"] = "Customer Details";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@model CustomerEditViewModel

<div class="p-3 md:p-6 lg:p-10 max-w-2xl mx-auto">

    <div class="flex justify-between items-start mb-8">
        <h1 class="text-2xl font-semibold text-gray-900 dark:text-white">@Model.FirstName @Model.LastName</h1>
        <div class="flex gap-2">
            <a asp-action="@nameof(CustomerController.Delete)" asp-route-id="@Model.Id"
               class="px-4 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-2xl hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors text-red-600 hover:bg-red-50 dark:hover:bg-red-900/10">
                Delete
            </a>
            <a asp-action="@nameof(CustomerController.Update)" asp-route-id="@Model.Id"
               class="px-4 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-2xl hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors">
                Edit
            </a>
            <a asp-action="Index"
               class="px-4 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-2xl hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors">
                Back
            </a>
        </div>
    </div>

    <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-3xl p-8 space-y-6">

        <div>
            <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wide">Email</p>
            <p class="text-lg text-gray-900 dark:text-white mt-1">@Model.Email</p>
        </div>

        <div>
            <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wide">Phone</p>
            <p class="text-lg text-gray-900 dark:text-white mt-1">@Model.Phone</p>
        </div>

        <div>
            <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wide">Address</p>
            <p class="text-gray-700 dark:text-gray-300 mt-1">@Model.Address</p>
        </div>

        <div>
            <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wide">City</p>
            <p class="text-lg text-gray-900 dark:text-white mt-1">@Model.City</p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 pt-4 border-t border-gray-100 dark:border-gray-700">
            <div>
                <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wide">Created</p>
                <p class="text-sm text-gray-900 dark:text-white mt-1">@Model.CreatedDate.ToString("g")</p>
            </div>
            <div>
                <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wide">Updated</p>
                <p class="text-sm text-gray-900 dark:text-white mt-1">@Model.UpdatedDate.ToString("g")</p>
            </div>
        </div>
    </div>
</div>
